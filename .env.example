# Notion 통합 시크릿 토큰 (필수)
# https://www.notion.so/my-integrations 에서 발급
NOTION_ACCESS_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 노션 데이터베이스 ID (필수)
# 데이터베이스 URL에서 ?v= 앞의 32자리 문자열
NOTION_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 태그 필터 — 이 값과 정확히 일치하는 태그가 있는 항목만 표시 (선택)
# 비워두면 전체 항목을 표시합니다
NOTION_FILTER_TEXT=모의고사

# Notion API 버전 (기본값: 2026-03-11)
NOTION_VERSION=2026-03-11

# 서버 포트 (기본값: 8787)
PORT=8787
